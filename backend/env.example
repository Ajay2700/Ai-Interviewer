OPENAI_API_KEY=your_openai_key

# ── DATABASE ───────────────────────────────────────────────────────────────────
# Supabase Transaction Pooler (port 6543):
#   USERNAME must be  postgres.<project-ref>  (include the dot + project ref!)
#   Find this in: Supabase → Project Settings → Database → Connection string → URI
#   Example: postgresql+psycopg2://postgres.abcdefghijklm:your_password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Direct connection (port 5432, no PgBouncer):
#   postgresql+psycopg2://postgres:your_password@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Local dev (SQLite — no setup needed, auto-used if DATABASE_URL is missing/wrong):
#   sqlite:///./interviewer_local.db
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<url_encoded_password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

ADMIN_API_KEY=your_admin_key
ADMIN_AUTH_SECRET=replace_with_random_secret
ADMIN_ALLOWED_EMAIL=admin@company.com
ALLOW_ADMIN_KEY_FALLBACK=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel URLs + keep localhost for local dev.
ALLOWED_ORIGINS=https://<candidate-app>.vercel.app,https://<admin-app>.vercel.app,http://localhost:5173,http://localhost:5174

# ── COST CONTROLS ──────────────────────────────────────────────────────────────
DAILY_TOKENS_FREE=1500
DAILY_QUESTIONS_FREE=10
MAX_QUESTIONS_PER_INTERVIEW=10
MAX_AI_QUESTIONS_PER_INTERVIEW=5
NEXT_QUESTION_COOLDOWN_SECONDS=5
REQUEST_LIMIT_PER_MINUTE=10
MAX_AUDIO_UPLOAD_BYTES=5242880
# Set true only in production where you want Windows-desktop enforcement.
WINDOWS_BROWSER_ONLY=false

# ── EMAIL (for admin OTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=app_password
SMTP_FROM_EMAIL=you@example.com
SMTP_SECURITY=starttls

# Optional: Resend.com as email fallback when SMTP is blocked.
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
